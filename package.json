{
  "name": "mythoria_admin",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.17.0",
  "scripts": {
    "dev": "next dev --turbopack --port 3001",
    "build": "cross-env NEXT_PRIVATE_SKIP_TURBOPACK=1 next build --webpack",
    "start": "next start --port 3001",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "logs": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\logs.ps1",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx -r dotenv/config ./src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:reset": "tsx -r dotenv/config ./src/db/reset.ts",
    "db:setup": "npm run db:reset && npm run db:push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx -r dotenv/config ./src/db/seed.ts",
    "sync-workflows-schema": "tsx -r dotenv/config ./scripts/sync-workflows-schema.ts",
    "sync-mythoria-db-schema": "tsx -r dotenv/config ./scripts/sync-mythoria-db-schema.ts",
    "seed:world-book-day": "tsx -r dotenv/config ./scripts/seed-world-book-day-2026.ts",
    "deploy": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\deploy.ps1",
    "deploy:fast": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\deploy.ps1 -Fast",
    "check:env": "tsx ./scripts/check-env-parity.ts"
  },
  "sideEffects": false,
  "dependencies": {
    "@google-cloud/pubsub": "^5.3.1",
    "@google-cloud/storage": "^7.21.0",
    "@google-cloud/workflows": "^5.1.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/jsdom": "^28.0.3",
    "@types/pg": "^8.20.0",
    "daisyui": "^5.5.23",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "googleapis": "^173.0.0",
    "handlebars": "^4.7.9",
    "jsdom": "^29.1.1",
    "next": "^16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "react-is": "^19.2.7",
    "recharts": "^3.8.1",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.2.0",
    "tsx": "^4.22.4",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "uuid": "^14.0.0",
    "vfile": "^6.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@next/eslint-plugin-next": "^16.2.9",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "baseline-browser-mapping": "^2.10.37",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "ts-jest": "^29.4.11",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "engines": {
    "node": "24.16.0"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "@google-cloud/storage": {
      "gaxios": "7.1.5",
      "retry-request": "8.0.3",
      "teeny-request": "10.1.3"
    }
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "protobufjs@7.6.4": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.11.1": true
  }
}
